<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AI Trade Demo</title>

<style>
*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial,sans-serif;
}

body{
background:#111827;
color:white;
padding:20px;
}

.container{
max-width:420px;
margin:auto;
}

.card{
background:#1f2937;
padding:15px;
border-radius:15px;
margin-bottom:15px;
}

.balance{
font-size:28px;
font-weight:bold;
color:#00ff99;
}

select,input{
width:100%;
padding:10px;
margin-top:10px;
border:none;
border-radius:8px;
font-size:16px;
}

.chart{
height:200px;
background:black;
border-radius:10px;
position:relative;
overflow:hidden;
margin-top:10px;
}

canvas{
width:100%;
height:100%;
}

.signal{
font-size:20px;
text-align:center;
margin-top:10px;
font-weight:bold;
}

.buttons{
display:flex;
gap:10px;
margin-top:15px;
}

button{
flex:1;
padding:15px;
font-size:18px;
border:none;
border-radius:10px;
cursor:pointer;
font-weight:bold;
}

.buy{
background:#00c853;
color:white;
}

.sell{
background:#d50000;
color:white;
}

.history{
margin-top:10px;
font-size:14px;
line-height:25px;
max-height:180px;
overflow:auto;
}
</style>
</head>

<body>

<div class="container">

<div class="card">
<div>Balance</div>
<div class="balance">$1000.00</div>
</div>

<div class="card">
<select>
<option>EUR/USD</option>
<option>BTC/USD</option>
<option>Gold</option>
</select>

<input type="number" id="amount" value="10">

<div class="chart">
<canvas id="chart"></canvas>
</div>

<div class="signal" id="signal">
AI Signal : Waiting...
</div>

<div class="buttons">
<button class="buy" onclick="trade('BUY')">
BUY ▲
</button>

<button class="sell" onclick="trade('SELL')">
SELL ▼
</button>
</div>

</div>

<div class="card">
<h3>Trade History</h3>
<div id="history" class="history"></div>
</div>

</div>

<script>

const canvas=document.getElementById("chart");
const ctx=canvas.getContext("2d");

canvas.width=380;
canvas.height=200;

let points=[];

for(let i=0;i<40;i++){
points.push(100+Math.random()*40);
}

function draw(){

ctx.clearRect(0,0,canvas.width,canvas.height);

ctx.beginPath();

ctx.strokeStyle="#00ff99";
ctx.lineWidth=2;

points.forEach((p,i)=>{
let x=i*10;
let y=p;

if(i==0)
ctx.moveTo(x,y);
else
ctx.lineTo(x,y);

});

ctx.stroke();

points.shift();

let last=points[points.length-1];

last+=Math.random()*20-10;

if(last<20)last=20;

if(last>180)last=180;

points.push(last);

}

setInterval(draw,500);

function updateSignal(){

let confidence=Math.floor(Math.random()*30)+70;

let direction=Math.random()>0.5?"BUY":"SELL";

document.getElementById("signal").innerHTML=
"AI Signal : "+direction+" ("+confidence+"%)";

}

setInterval(updateSignal,3000);

function trade(type){

let amount=document.getElementById("amount").value;

let time=new Date().toLocaleTimeString();

let result=Math.random()>0.5?"WIN":"LOSS";

document.getElementById("history").innerHTML=
"<div>"+time+" | "+type+
" | $"+amount+
" | "+result+"</div>"
+
document.getElementById("history").innerHTML;

}

updateSignal();

</script>

</body>
</html>
