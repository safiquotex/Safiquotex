<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>AI Trade Pro</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;500;700&display=swap" rel="stylesheet">

<style>
*{margin:0;padding:0;box-sizing:border-box;font-family:Poppins,sans-serif}
body{
background:#050816;
color:#fff;
overflow-x:hidden;
}

header{
display:flex;
justify-content:space-between;
align-items:center;
padding:20px 8%;
position:fixed;
width:100%;
background:rgba(0,0,0,.35);
backdrop-filter:blur(12px);
z-index:1000;
}

.logo{
font-size:30px;
font-weight:700;
color:#00ff9d;
}

nav a{
color:#fff;
text-decoration:none;
margin-left:25px;
transition:.3s;
}

nav a:hover{
color:#00ff9d;
}

.hero{
min-height:100vh;
display:flex;
align-items:center;
justify-content:center;
text-align:center;
padding:100px 20px;
background:radial-gradient(circle,#13234b,#050816);
}

.hero h1{
font-size:60px;
margin-bottom:20px;
}

.hero span{
color:#00ff9d;
}

.hero p{
max-width:700px;
margin:auto;
color:#cbd5e1;
font-size:18px;
}

.buttons{
margin-top:35px;
}

.btn{
display:inline-block;
padding:15px 35px;
border-radius:12px;
text-decoration:none;
font-weight:bold;
margin:10px;
transition:.3s;
}

.primary{
background:#00ff9d;
color:#000;
}

.secondary{
border:2px solid #00ff9d;
color:#00ff9d;
}

.btn:hover{
transform:translateY(-4px);
}

.features{
padding:90px 8%;
display:grid;
grid-template-columns:repeat(auto-fit,minmax(260px,1fr));
gap:25px;
}

.card{
background:rgba(255,255,255,.05);
border:1px solid rgba(255,255,255,.08);
backdrop-filter:blur(15px);
padding:30px;
border-radius:18px;
transition:.3s;
}

.card:hover{
transform:translateY(-8px);
box-shadow:0 0 25px #00ff9d55;
}

.card h3{
margin-bottom:15px;
color:#00ff9d;
}

.stats{
padding:80px 8%;
display:flex;
justify-content:space-around;
flex-wrap:wrap;
text-align:center;
}

.stat h2{
font-size:42px;
color:#00ff9d;
}

footer{
padding:30px;
text-align:center;
background:#02040d;
margin-top:40px;
color:#aaa;
}
</style>
</head>

<body>

<header>
<div class="logo">AI Trade Pro</div>

<nav>
<a href="#">Home</a>
<a href="#">Features</a>
<a href="#">Pricing</a>
<a href="#">About</a>
<a href="#">Contact</a>
</nav>
</header>

<section class="hero">

<div>

<h1>Trade Smarter with <span>AI</span></h1>

<p>
A modern demo landing page showcasing an AI-powered trading platform with a clean premium interface.
</p>

<div class="buttons">

<a href="#" class="btn primary">
Get Started
</a>

<a href="#" class="btn secondary">
Live Demo
</a>

</div>

</div>

</section>

<section class="features">

<div class="card">
<h3>AI Market Insights</h3>
<p>Explore AI-generated market analysis and educational trading insights.</p>
</div>

<div class="card">
<h3>Interactive Charts</h3>
<p>Ready to integrate advanced chart libraries for visualization.</p>
</div>

<div class="card">
<h3>Fast & Responsive</h3>
<p>Optimized interface for desktop, tablet, and mobile devices.</p>
</div>

<div class="card">
<h3>Secure Dashboard</h3>
<p>Modern authentication-ready layout for future expansion.</p>
</div>

</section>

<section class="stats">

<div class="stat">
<h2 id="users">0</h2>
<p>Demo Users</p>
</div>

<div class="stat">
<h2 id="signals">0</h2>
<p>AI Signals</p>
</div>

<div class="stat">
<h2 id="countries">0</h2>
<p>Countries</p>
</div>

</section>

<footer>

© 2026 AI Trade Pro Demo

</footer>

<script>

function animate(id,target){

let n=0;

let speed=target/100;

let x=setInterval(function(){

n+=speed;

document.getElementById(id).innerHTML=Math.floor(n);

if(n>=target){

document.getElementById(id).innerHTML=target;

clearInterval(x);

}

},20);

}

animate("users",12000);

animate("signals",450000);

animate("countries",120);

</script>

</body>
</html>
